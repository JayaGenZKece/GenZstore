# ─── DATABASE ──────────────────────────────────────────────
# Railway: buka project → Add Service → Database → PostgreSQL
# Salin connection string dari tab "Connect"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── JWT ───────────────────────────────────────────────────
# Generate random string panjang: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="ganti_dengan_string_random_panjang_minimal_64_karakter"

# ─── SERVER ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── FRONTEND ──────────────────────────────────────────────
# URL frontend Vercel kamu (setelah deploy)
FRONTEND_URL="https://mlshop.vercel.app"

# ─── CLOUDINARY (upload gambar, gratis) ────────────────────
# Daftar di cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── PAYMENT GATEWAY (opsional) ────────────────────────────
# Midtrans: daftar di midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY="your_midtrans_server_key"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key"
MIDTRANS_IS_PRODUCTION=false
